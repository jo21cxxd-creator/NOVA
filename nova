local function createTab(label)
    local Btn = Instance.new("TextButton")
    Btn.Parent = Sidebar
    Btn.Size = UDim2.new(1, 0, 0, 32)
    Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 26)
    Btn.Text = label
    Btn.TextColor3 = Color3.fromRGB(170, 170, 185)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 12
    Btn.BorderSizePixel = 0
    Btn.ZIndex = 3
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 7)

    local Ind = Instance.new("Frame")
    Ind.Parent = Btn
    Ind.Size = UDim2.new(0, 3, 0.55, 0)
    Ind.Position = UDim2.new(0, 0, 0.22, 0)
    Ind.BackgroundColor3 = RED
    Ind.BorderSizePixel = 0
    Ind.Visible = false
    Instance.new("UICorner", Ind).CornerRadius = UDim.new(0, 2)

    local Page = Instance.new("Frame")
    Page.Parent = Content
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false

    table.insert(tabPages, Page)
    table.insert(tabButtons, {btn=Btn, ind=Ind})

    Btn.MouseButton1Click:Connect(function()
        for _, p in pairs(tabPages) do p.Visible = false end
        for _, t in pairs(tabButtons) do
            t.btn.BackgroundColor3 = Color3.fromRGB(20, 20, 26)
            t.btn.TextColor3 = Color3.fromRGB(170, 170, 185)
            t.ind.Visible = false
        end
        Page.Visible = true
        Btn.BackgroundColor3 = Color3.fromRGB(38, 20, 20)
        Btn.TextColor3 = Color3.new(1, 1, 1)
        Ind.Visible = true
    end)

    return Btn, Page
end

