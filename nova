local function activateTab(Page, Btn, Ind)
    for _, p in pairs(tabPages) do p.Visible = false end
    for _, t in pairs(tabButtons) do
        t.btn.BackgroundColor3 = Color3.fromRGB(20, 20, 26)
        t.btn.TextColor3 = Color3.fromRGB(170, 170, 185)
        t.ind.Visible = false
    end
    Page.Visible = true
    Btn.BackgroundColor3 = Color3.fromRGB(38, 20, 20)
    Btn.TextColor3 = Color3.new(1, 1, 1)
    Ind.Visible = true
end

