    local RStr = Instance.new("UIStroke", Row)
    RStr.Color = GRAY
    RStr.Thickness = 1

    local Lbl = Instance.new("TextLabel")
    Lbl.Parent = Row
    Lbl.Size = UDim2.new(0.72, 0, 1, 0)
    Lbl.Position = UDim2.new(0, 10, 0, 0)
    Lbl.BackgroundTransparency = 1
    Lbl.Text = label
    Lbl.TextColor3 = WHITE
    Lbl.Font = Enum.Font.Gotham
    Lbl.TextSize = 12
    Lbl.TextXAlignment = Enum.TextXAlignment.Left

    local Track = Instance.new("Frame")
    Track.Parent = Row
    Track.Size = UDim2.new(0, 38, 0, 16)
    Track.Position = UDim2.new(1, -46, 0.5, -8)
    Track.BackgroundColor3 = GRAY
    Track.BorderSizePixel = 0
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

    local Knob = Instance.new("Frame")
    Knob.Parent = Track
    Knob.Size = UDim2.new(0, 11, 0, 11)
    Knob.Position = UDim2.new(0, 3, 0.5, -5.5)
    Knob.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
    Knob.BorderSizePixel = 0
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)

    local state = default or false
    local function apply(val)
        state = val
        if val then
            TweenService:Create(Track, TweenInfo.new(0.2), {BackgroundColor3=RED}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.2), {
                Position=UDim2.new(0,22,0.5,-5.5),
                BackgroundColor3=Color3.new(1,1,1)
            }):Play()
            RStr.Color = RED
            if onOn then pcall(onOn) end
        else
            TweenService:Create(Track, TweenInfo.new(0.2), {BackgroundColor3=GRAY}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.2), {
                Position=UDim2.new(0,3,0.5,-5.5),
                BackgroundColor3=Color3.fromRGB(180,180,180)
            }):Play()
            RStr.Color = GRAY
            if onOff then pcall(onOff) end
        end
    end
    apply(state)

    local Hit = Instance.new("TextButton")
    Hit.Parent = Row
    Hit.Size = UDim2.new(1, 0, 1, 0)
    Hit.BackgroundTransparency = 1
    Hit.Text = ""
    Hit.ZIndex = 3
    Hit.MouseButton1Click:Connect(function() apply(not state) end)
    return apply
end

