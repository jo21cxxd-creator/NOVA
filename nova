local function fetchServers()
    clearServers()
    servers = {}
    SevSearchBtn.Text = "Buscando..."
    local cursor = ""
    for _ = 1, 5 do
        local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
        if cursor ~= "" then url = url.."&cursor="..cursor end
        local ok, result = pcall(function() return game:HttpGet(url) end)
        if ok then
            local data = HttpService:JSONDecode(result)
            if data and data.data then
                for _, s in pairs(data.data) do
                    if s.id ~= currentJob and s.playing < s.maxPlayers then
                        table.insert(servers, s)
                    end
                end
            end
            cursor = data.nextPageCursor
            if not cursor or cursor == "" then break end
        end
    end
    table.sort(servers, function(a,b) return a.playing < b.playing end)
    for _, s in pairs(servers) do addServerEntry(s) end
    task.defer(function()
        SevScroll.CanvasSize = UDim2.new(0, 0, 0, SevLayout.AbsoluteContentSize.Y + 8)
    end)
    SevSearchBtn.Text = "Buscar ("..#servers..")"
end

SevSearchBtn.MouseButton1Click:Connect(fetchServers)
SevHopBtn.MouseButton1Click:Connect(function()
    if #servers == 0 then return end
    TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[1].id, LP)
end)

