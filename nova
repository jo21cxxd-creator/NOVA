-- ============================================================
-- FISCH v3.8 — ROD DETECTION: basada en estructura interna
--
-- Las cañas en Fisch tienen una Folder llamada "events"
-- con RemoteEvents exclusivos del sistema de pesca:
--   - castAsync   (RemoteFunction)
--   - handlebobber (RemoteEvent)
--   - catchfinish  (RemoteEvent)
--
-- Ningun pez, treasure map, bag u otro item tiene esto.
-- Deteccion 100% automatica sin depender del nombre del tool.
-- ============================================================

local fishCfg   = {fish=false, shake=false, reel=false}
local fishStats = {cast=0, catch=0}
local fishThread = nil
local fishState  = "idle"
local isHolding  = false

-- ============================================================
-- isRod v3.8 — Detecta cañas por estructura interna
-- Busca la Folder "events" con RemoteEvents exclusivos de Fisch
-- ============================================================
local function isRod(tool)
    if not tool:IsA("Tool") then return false end

    local events = tool:FindFirstChild("events")
    if not events then return false end

    -- Cualquiera de estos es suficiente para confirmar que es caña
    if events:FindFirstChild("castAsync")    then return true end
    if events:FindFirstChild("handlebobber") then return true end
    if events:FindFirstChild("catchfinish")  then return true end

    return false
end

local function getVU()
    local ok, vu = pcall(function()
        return cloneref(game:GetService("VirtualUser"))
    end)
    return (ok and vu) or game:GetService("VirtualUser")
end

local function vuDown()
    pcall(function()
        local cam = workspace.CurrentCamera
        local c = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        getVU():Button1Down(c, cam.CFrame)
    end)
end

local function vuUp()
    pcall(function()
        local cam = workspace.CurrentCamera
        local c = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        getVU():Button1Up(c, cam.CFrame)
    end)
end

local function clickAt(pos)
    pcall(function()
        local cam = workspace.CurrentCamera
        getVU():Button1Down(pos, cam.CFrame)
        task.wait(0.05)
        getVU():Button1Up(pos, cam.CFrame)
    end)
end

local function holdOn()
    if not isHolding then
        isHolding = true
        vuDown()
    end
end

local function holdOff()
    if isHolding then
        isHolding = false
        vuUp()
    end
end

local function isCasting()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "bobber" and v:IsA("MeshPart") then return true end
    end
    return false
end

-- hasRod v3.8 — usa isRod para verificar si hay caña equipada
local function hasRod()
    if isCasting() then return true end
    local ch = LP.Character
    if not ch then return false end
    local equipped = ch:FindFirstChildOfClass("Tool")
    if equipped and isRod(equipped) then return true end
    return false
end

-- equipRod v3.8 — equipa automaticamente la primera caña
-- detectada por estructura interna, sin importar el nombre
local function equipRod()
    pcall(function()
        local ch = LP.Character
        local h  = ch and ch:FindFirstChildOfClass("Humanoid")
        if not h then return end
        for _, tool in pairs(LP.Backpack:GetChildren()) do
            if isRod(tool) then
                h:EquipTool(tool)
                task.wait(0.8)
                break
            end
        end
    end)
end

local function isShaking()
    local shakeui = PGui:FindFirstChild("shakeui")
    return shakeui ~= nil and shakeui.Enabled == true
end

local function isReeling()
    local reel = PGui:FindFirstChild("reel")
    return reel ~= nil and reel.Enabled == true
end

local function isCaught()
    for _, gui in pairs(PGui:GetChildren()) do
        local n = gui.Name:lower()
        if n:find("catch") or n == "fishcatch" or n == "catchresult" then
            return true
        end
    end
    return false
end

local function doShake()
    pcall(function()
        local shakeui = PGui:FindFirstChild("shakeui")
        if not shakeui then return end
        local safezone = shakeui:FindFirstChild("safezone")
        if safezone then
            local button = safezone:FindFirstChild("button")
            if button and button.Visible then
                clickAt(button.AbsolutePosition + button.AbsoluteSize/2)
                return
            end
        end
        for _, v in pairs(shakeui:GetDescendants()) do
            if (v:IsA("TextButton") or v:IsA("ImageButton")) and v.Visible then
                clickAt(v.AbsolutePosition + v.AbsoluteSize/2)
                return
            end
        end
    end)
end

local function doReel()
    pcall(function()
        local reel = PGui:FindFirstChild("reel")
        if not reel then
            holdOn() task.wait(0.06) holdOff() task.wait(0.06)
            return
        end
        local bar = reel:FindFirstChild("bar")
        if not bar then
            holdOn() task.wait(0.06) holdOff() task.wait(0.06)
            return
        end
        local fishFrame = bar:FindFirstChild("fish")
        local playerbar = bar:FindFirstChild("playerbar")
        if not fishFrame or not playerbar then
            holdOn() task.wait(0.06) holdOff() task.wait(0.06)
            return
        end
        local pbCenter  = playerbar.AbsolutePosition.X + playerbar.AbsoluteSize.X / 2
        local fishLeft  = fishFrame.AbsolutePosition.X
        local fishRight = fishLeft + fishFrame.AbsoluteSize.X
        local fishCenter= fishLeft + fishFrame.AbsoluteSize.X / 2
        local margin = 6
        if pbCenter < fishLeft + margin then
            holdOn()
        elseif pbCenter > fishRight - margin then
            holdOff()
        elseif pbCenter < fishCenter then
            holdOn()
        else
            holdOff()
        end
    end)
end

-- ============================================================
-- getCastFill v3.9 — Lee la barra de poder del casteo
-- Estructura detectada:
--   HumanoidRootPart
--   └── BillboardGui | power
--       └── Frame | powerbar
--           ├── Frame | bar
--           │   └── Frame | fill  ← se llena al hacer hold
--           └── Frame | green     ← zona de perfect cast
-- ============================================================
local function getCastFill()
    local ch = LP.Character
    if not ch then return nil, nil end
    local hrp = ch:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil end
    local power = hrp:FindFirstChild("power")
    if not power then return nil, nil end
    local powerbar = power:FindFirstChild("powerbar")
    if not powerbar then return nil, nil end
    local bar = powerbar:FindFirstChild("bar")
    if not bar then return nil, nil end
    return bar:FindFirstChild("fill"), bar
end

local function isPowerBarVisible()
    local fill, _ = getCastFill()
    return fill ~= nil
end

local function doCast()
    pcall(function()
        -- Inicia el hold para comenzar el casteo
        holdOn()

        -- Espera a que aparezca la powerbar (max 3 segundos)
        local timeout = tick() + 3
        local barDetected = false
        while tick() < timeout do
            if isPowerBarVisible() then
                barDetected = true
                break
            end
            task.wait(0.05)
        end

        if barDetected then
            -- Monitorea el fill hasta llegar al 80%
            timeout = tick() + 4
            while tick() < timeout do
                local fill, bar = getCastFill()
                if not fill or not bar then break end
                local fillH = fill.AbsoluteSize.Y
                local barH  = bar.AbsoluteSize.Y
                if barH > 0 and (fillH / barH) >= 0.8 then
                    break
                end
                task.wait(0.03)
            end
        else
            -- Sin powerbar, espera fijo como fallback
            task.wait(0.9)
        end

        holdOff()
        fishStats.cast = fishStats.cast + 1
        task.wait(1.2)
    end)
end

local function startFish()
    if fishThread then task.cancel(fishThread) fishThread = nil end
    fishState = "idle"
    holdOff()

    fishThread = task.spawn(function()
        local caughtCd = false
        while fishCfg.fish do
            pcall(function()
                local casting = isCasting()
                if not casting and not hasRod() then
                    fishState = "equipping"
                    holdOff()
                    equipRod()
                    return
                end
                if isReeling() then
                    fishState = "reeling"
                    if fishCfg.reel then doReel() end
                    task.wait(0.05)
                    return
                end
                if isCaught() then
                    if not caughtCd then
                        caughtCd = true
                        fishState = "caught"
                        fishStats.catch = fishStats.catch + 1
                        holdOff()
                        task.wait(2.5)
                        caughtCd = false
                        fishState = "idle"
                    end
                    return
                end
                if casting then
                    fishState = "waiting"
                    if fishCfg.shake and isShaking() then
                        fishState = "shaking"
                        doShake()
                    end
                    task.wait(0.15)
                    return
                end
                fishState = "casting"
                doCast()
                fishState = isCasting() and "waiting" or "idle"
            end)
            task.wait(0.05)
        end
        fishState = "idle"
        holdOff()
    end)
end

local function stopFish()
    fishCfg.fish = false
    if fishThread then task.cancel(fishThread) fishThread = nil end
    fishState = "idle"
    holdOff()
end

