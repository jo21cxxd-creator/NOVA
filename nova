local fishCfg = {fish=false, shake=false, reel=false}
local fishStats = {cast=0, catch=0}
local fishLoop = nil

local function fishClick()
    pcall(function()
        local vu = cloneref(game:GetService("VirtualUser"))
        local cam = workspace.CurrentCamera
        local c = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        vu:Button1Down(c, cam.CFrame)
        task.wait(0.05)
        vu:Button1Up(c, cam.CFrame)
    end)
end

local function hasRod()
    local ch = LP.Character
    if not ch then return false end
    for _, v in pairs(ch:GetChildren()) do
        if v:IsA("Tool") then
            local n = v.Name:lower()
            if n:find("rod") or n:find("fish") then return true end
        end
    end
    return false
end

local function equipRod()
    pcall(function()
        for _, t in pairs(LP.Backpack:GetChildren()) do
            if t:IsA("Tool") then
                local n = t.Name:lower()
                if n:find("rod") or n:find("fish") or n:find("cana") then
                    local h = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
                    if h then h:EquipTool(t) task.wait(0.8) end
                end
            end
        end
    end)
end

local function isShaking()
    local s = PGui:FindFirstChild("shakeui", true)
    return s ~= nil and s.Enabled == true
end

local function isReeling()
    local r = PGui:FindFirstChild("reel", true)
    return r ~= nil and r.Enabled == true
end

local function isCaught()
    local c = PGui:FindFirstChild("catch", true)
    return c ~= nil and c.Visible == true
end

local function isCasting()
    -- bobber MeshPart solo existe cuando la cana esta lanzada
    -- bobber StringValue existe siempre (es del inventario)
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "bobber" and v:IsA("MeshPart") then
            return true
        end
        if v.Name == "handlebobber" and v:IsA("RemoteEvent") then
            return true
        end
    end
    return false
end

local function startFish()
    if fishLoop then fishLoop:Disconnect() fishLoop = nil end
    local ct = 0
    local last = ""
    fishLoop = RunService.Heartbeat:Connect(function(dt)
        if not fishCfg.fish then return end
        pcall(function()
            if not hasRod() then equipRod() task.wait(1) return end
            if fishCfg.shake and isShaking() then
                last = "shake"
                local su = PGui:FindFirstChild("shakeui", true)
                if su then
                    local ic = su:FindFirstChild("GamepadIcon", true)
                    if ic and ic.Parent then
                        local p = ic.Parent
                        if p:IsA("TextButton") or p:IsA("ImageButton") then
                            p.MouseButton1Click:Fire()
                        else fishClick() end
                    else fishClick() end
                else fishClick() end
                task.wait(0.08)
                return
            end
            if fishCfg.reel and isReeling() then
                last = "reel"
                local rg = PGui:FindFirstChild("reel", true)
                if rg then
                    local pb = rg:FindFirstChild("playerbar", true)
                    local ff = rg:FindFirstChild("fish", true)
                    if pb and ff then
                        if math.abs(pb.AbsolutePosition.Y - ff.AbsolutePosition.Y) > 15 then
                            fishClick()
                        end
                    else fishClick() end
                else fishClick() end
                task.wait(0.05)
                return
            end
            if isCaught() then
                if last ~= "caught" then
                    last = "caught"
                    fishStats.catch = fishStats.catch + 1
                end
                task.wait(1.5)
                return
            end
            if isCasting() then last = "wait" task.wait(0.2) return end
            ct = ct + dt
            if ct >= 1.5 then
                ct = 0
                last = "cast"
                fishClick()
                fishStats.cast = fishStats.cast + 1
                task.wait(1)
            end
        end)
    end)
end

local function stopFish()
    if fishLoop then fishLoop:Disconnect() fishLoop = nil end
    fishCfg.fish = false
end

